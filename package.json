{
  "name": "@basuruk/nuron",
  "version": "2.0.0",
  "description": "Nuron - temporal knowledge graph memory for OpenClaw with Memory Cortex adaptive importance scoring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "openclaw.plugin.json",
    "MEMORY.md",
    "AXON.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "sleep-cycle": "tsx scripts/sleep-consolidation.ts",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sinclair/typebox": "^0.32.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "openclaw",
    "memory",
    "nuron",
    "knowledge-graph",
    "ai-agent",
    "temporal-memory",
    "agentic",
    "memory-cortex"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/basuruk/nuron"
  }
}
